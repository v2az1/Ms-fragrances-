{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Fragrance product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "price": { "type": "number" },
              "stock": { "type": "integer" }
            },
            "required": ["size", "price", "stock"]
          }
        }
      },
      "required": ["name", "price", "description", "image", "category", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "products": { "type": "array" },
        "totalPrice": { "type": "number" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Ordered", "Confirmed", "Out for Delivery", "Delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "products", "totalPrice", "customerName", "phone", "address", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    }
  }
}
